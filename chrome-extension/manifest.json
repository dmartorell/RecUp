{
  "manifest_version": 3,
  "name": "RecUp",
  "version": "2.0.0",
  "description": "Genera tickets de incidencias en ClickUp usando audio o texto.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "tabs", "contextMenus", "scripting"],
  "host_permissions": ["https://recup.onrender.com/*", "http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  }
}
