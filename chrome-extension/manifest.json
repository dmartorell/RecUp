{
  "manifest_version": 3,
  "name": "Bugshot",
  "version": "1.0.0",
  "description": "Genera tickets de incidencias en Clickup usando audio o texto. El micrófono solo se activa al pulsar grabar.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"]
}
